# mysql
地址：localhost:3306
用户：root
密码：your_mysql_password
# oss
endpoint: https://oss-cn-hangzhou.aliyuncs.com
bucket-name: your_bucket_name
region: cn-hangzhou
OSS_ACCESS_KEY_ID  your_access_key_id
OSS_ACCESS_KEY_SECRET  your_access_key_secret
# 大模型
url  https://your_api_endpoint/v1
key   your_api_key
模型  mimo-v2.5-pro
# postgresql
端口 5432
Host: localhost
Username: your_postgresql_user
密码 your_postgresql_password
  # 阿里云DashScope Embedding配置（OpenAI兼容模式）
  embedding-url: https://dashscope.aliyuncs.com/compatible-mode/v1
  embedding-key: your_embedding_api_key
  embedding-model: text-embedding-v1
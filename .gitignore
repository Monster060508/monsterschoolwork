# ======================================
# 通用 Git 忽略（防止敏感信息泄露）
# ======================================
.DS_Store
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.log
tmp/
temp/

# ======================================
# Java / Maven 项目编译文件（必须忽略）
# ======================================
target/
build/
*.class
*.jar
*.war
*.ear
*.pid

# ======================================
# 敏感配置文件（核心！防止密钥提交）
# ======================================
application.yml
application-dev.yml
application-prod.yml
bootstrap.yml
*.properties
*.env
.env
.env.*
config/
conf/

# ======================================
# 你的项目敏感文档（直接屏蔽）
# ======================================
配置信息.md
配置文档.md
*密码*.md
*密钥*.md
*账号*.md
*secret*.md
*accesskey*.md

# ======================================
# 允许配置模板文件（.example后缀）
# ======================================
!*.example